<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 500" width="900" height="500">
  <defs>
    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1020"/>
      <stop offset="100%" style="stop-color:#0a0a0a"/>
    </linearGradient>
  </defs>
  <rect width="900" height="500" fill="url(#g)"/>
  <!-- storyboard grid -->
  <rect x="120" y="100" width="200" height="130" rx="6" fill="#1e1e2e" stroke="#333" stroke-width="1"/>
  <rect x="340" y="100" width="200" height="130" rx="6" fill="#1e1e2e" stroke="#333" stroke-width="1"/>
  <rect x="560" y="100" width="200" height="130" rx="6" fill="#1e1e2e" stroke="#333" stroke-width="1"/>
  <rect x="120" y="250" width="200" height="130" rx="6" fill="#1e1e2e" stroke="#333" stroke-width="1"/>
  <rect x="340" y="250" width="200" height="130" rx="6" fill="#1e1e2e" stroke="#333" stroke-width="1"/>
  <rect x="560" y="250" width="200" height="130" rx="6" fill="#f87800" opacity="0.15" stroke="#f87800" stroke-width="1"/>
  <!-- pencil icon -->
  <path d="M600 130 L640 90 L660 110 L620 150 Z" fill="#f87800" opacity="0.6"/>
  <line x1="600" y1="130" x2="595" y2="155" stroke="#f87800" stroke-width="2" opacity="0.6"/>
</svg>